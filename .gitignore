# ESP-IDF build artifacts (huge, regenerated by idf.py build)
build/

# Downloaded components (regenerated by idf.py reconfigure)
managed_components/

# ESP-IDF config (machine-specific paths, regenerated by menuconfig)
sdkconfig
sdkconfig.old

# Log files from test runs
*.log
log.*

# TLS certificates and private keys (security-sensitive)
*.pem
*.key
ca.crt
server.crt
server.key

# OS junk
.DS_Store
Thumbs.db

# Node-RED runtime
.node-red/
node_modules/

# Python
__pycache__/
*.pyc